# ==========================================
# Nexa Agent — 环境变量配置模板
# ==========================================

# --- LLM ---
# 可选: deepseek | kimi | glm
LLM_BACKEND=deepseek
LLM_MODEL=deepseek-v4-flash
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096

# DeepSeek V4 (https://platform.deepseek.com/api_keys)
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Kimi K2.6 (https://platform.moonshot.cn)
MOONSHOT_API_KEY=sk-your-kimi-api-key
KIMI_BASE_URL=https://api.moonshot.cn/v1

# GLM-5.1 智谱 (https://open.bigmodel.cn)
ZHIPU_API_KEY=your-zhipu-api-key

# --- VLM (llama.cpp 本地) ---
# ./llama-server -m MiniCPM-V-4_6-Q4_K_M.gguf --mmproj mmproj-model-f16.gguf --port 8080
VLM_MODEL_NAME=MiniCPM-V-4_6-Q4_K_M.gguf
VLM_BASE_URL=http://127.0.0.1:8080/v1
VLM_CTX_SIZE=4096

# --- Tavily (网页搜索 + 内容提取) ---
TAVILY_API_KEY=tvly-your-tavily-api-key

# --- 数据库 ---
# DB_PATH=data/nexa_agent.db

# --- 日志 ---
LOG_LEVEL=INFO

# --- Streamlit 后端地址 ---
# NEXA_API_BASE=http://localhost:8000
