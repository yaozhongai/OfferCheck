# ==========================================
# Nexa Agent — 环境变量配置模板
# ==========================================

# --- LLM Provider (nexa_agent 核心) ---
# 可选: gmi | deepseek。未设置时有 GMI_API_KEY 则用 gmi，否则 deepseek
LLM_PROVIDER=gmi

# GMI Cloud Inference Engine (https://console.gmicloud.ai, OpenAI 兼容)
GMI_API_KEY=your-gmi-api-key
GMI_BASE_URL=https://api.gmi-serving.com/v1
# 可选：按当前套餐填写混合模型的加权单价，前端会显示单次调查成本估算。
# 未配置时只展示耗时/步数/来源数/Token，不会编造价格。
# OFFERCHECK_INPUT_USD_PER_1M_TOKENS=
# OFFERCHECK_OUTPUT_USD_PER_1M_TOKENS=
# 模型分层可覆盖
# STRONG_MODEL=deepseek-ai/DeepSeek-V4-Pro      # 首步规划（默认）
# FAST_MODEL=deepseek-ai/DeepSeek-V4-Flash       # 后续执行（默认）
# UPGRADE_MODEL=Qwen/Qwen3.6-35B-A3B            # tool-call 备援（连续 2 步未发 tool_calls 时自动切入）
# 云端图片理解（analyze_image_cloud）— 有 GMI key 时默认走 Gemini 3.1
# VISION_PROVIDER=gmi                                        # gmi | kimi（默认有 GMI key 则 gmi）
# VISION_MODEL=google/gemini-3.1-flash-lite-preview         # 普通图片
# VISION_MODEL_COMPLEX=google/gemini-3.1-pro-preview        # 复杂/模糊图（空响应自动升级）

# --- LLM ---
# 可选: deepseek | kimi | glm
LLM_BACKEND=deepseek
LLM_MODEL=deepseek-v4-flash
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096

# DeepSeek V4 (https://platform.deepseek.com/api_keys)
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Kimi K2.6 (https://platform.moonshot.cn)
MOONSHOT_API_KEY=sk-your-kimi-api-key
KIMI_BASE_URL=https://api.moonshot.cn/v1

# GLM-5.1 智谱 (https://open.bigmodel.cn)
ZHIPU_API_KEY=your-zhipu-api-key

# --- VLM (llama.cpp 本地) ---
# ./llama-server -m MiniCPM-V-4_6-Q4_K_M.gguf --mmproj mmproj-model-f16.gguf --port 8080
VLM_MODEL_NAME=MiniCPM-V-4_6-Q4_K_M.gguf
VLM_BASE_URL=http://127.0.0.1:8080/v1
VLM_CTX_SIZE=4096

# --- Tavily (网页搜索 + 内容提取) ---
TAVILY_API_KEY=tvly-your-tavily-api-key

# --- 搜索 provider 层 (可插拔 + 有序降级) ---
# provider 优先级，逗号分隔。默认 Tavily 优先，额度尽时自动切自建 SearXNG
# SEARCH_PROVIDER_ORDER=tavily,searxng,exa,ddg
# SEARCH_MAX_RESULTS=5
# 自建 SearXNG 后端地址 (可选 opt-in；见 searxng/ 目录，docker compose up -d 启动后再取消注释)
# 不设置则跳过 SearXNG，直接按 tavily → exa → ddg 降级
# SEARXNG_BASE_URL=http://localhost:8888
# Exa 神经检索 (可选，1000/月免费，免信用卡): https://exa.ai
# EXA_API_KEY=
# 健康熔断：连续失败 N 次后冷却 M 秒内跳过该 provider
# SEARCH_HEALTH_FAIL_THRESHOLD=3
# SEARCH_HEALTH_COOLDOWN=120

# --- 数据库 ---
# DB_PATH=data/nexa_agent.db

# --- 日志 ---
LOG_LEVEL=INFO

# --- Streamlit 后端地址 ---
# NEXA_API_BASE=http://localhost:8000
