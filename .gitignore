# ==========================================
# Nexa Agent — .gitignore
# ==========================================

# 环境变量 (含 API Key)
.env

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
*.egg

# 虚拟环境
venv/
.venv/
env/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Jupyter
.ipynb_checkpoints/

# pytest
.pytest_cache/
htmlcov/
.coverage
coverage.xml

# ── 项目数据 ──
# 数据库 + 上传文件 (全部在 data/ 下)
data/

# ── 日志 ──
logs/
*.log

# ── 上传文件目录 ──
uploads/

# ── 测试图片 / 临时文件 ──
# 防止测试时把图片散落在项目根目录
/*.png
/*.jpg
/*.jpeg
/*.pdf
/*.gif
/*.webp
/*.bmp

# 临时文件
*.tmp
*.bak
*.cache
*.orig

# ── Claude Code ──
.claude/
CLAUDE.md

# ── 内部/开发产物：不进公开仓库 ──
# 设计深潜/会议纪要/规划稿等内部文档
docs/
# 测试与用例：版本化纯单测（test_*.py，不含 key），仍忽略 API smoke（gmi_api_test.py）
# 及 *_test.py 命名的用例。注意用 tests/* 而非 tests/——排除整个目录会阻止 ! 例外生效。
tests/*
!tests/test_*.py
# dev-loop 自定义 skill 与工作区
skills/

# ── 脚本 / 运维文件 ──
scripts/

# ── 知识库本地文件 ──
data/extracts/

# ── Milvus 本地数据 ──
milvus_data/

# ── 其他中间产物 ──
*.db-shm
*.db-wal

1780846142722.png
milvus_manager.py

# 内部文档（本地保留，不入公开仓库）
SPEC.md
CLAUDE.md

# 开发/测试用（本地保留，不入公开仓库）
skills/
tests/
pytest.ini

# ── 本地运行产物：eval 输出 / 报告 / 路演稿（本地保留，不入公开仓库）──
nexa_agent/results/
/report_*.json
waic_roadshow.xml
